[Unit]
Description=AzagasPay Backend Service
After=network.target

[Service]
Type=simple
User=dhonaldduck
WorkingDirectory=/home/dhonaldduck/Documents/azagaspay-project/azagaspay/azagaspay-backend
ExecStart=/usr/bin/node --experimental-sqlite src/index.js
Restart=on-failure
Environment=NODE_ENV=development PORT=3000

[Install]
WantedBy=multi-user.target
sudo journalctl -u azagaspay -n 20 --no-pager
