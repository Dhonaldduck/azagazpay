{
  "name": "azagaspay-backend",
  "version": "1.0.0",
  "description": "Backend API AzagasPay — Sistem Pembayaran Kantin Digital",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "setup": "node src/database/migrate.js && node src/database/seed.js",
    "db:seed": "node src/database/seed.js",
    "db:reset": "rm -f azagaspay.db && node src/database/migrate.js && node src/database/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
