# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (SQLite — tidak perlu install apapun!) ──
DATABASE_URL="file:./azagaspay.db"

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=azagaspay_jwt_secret_ganti_di_production_minimal_32_char
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=azagaspay_refresh_secret_ganti_di_production
JWT_REFRESH_EXPIRES_IN=30d

# ─── NFC Security ─────────────────────────────────────
NFC_ENCRYPTION_KEY=azagasnfc12345678
NFC_ENCRYPTION_IV=azagasiv12345678

# ─── IoT Device ───────────────────────────────────────
IOT_DEVICE_SECRET=secret_iot_azagaspay_2024

# ─── CORS ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.100:3000
